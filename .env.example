NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ADMIN_USER=your_admin_username
ADMIN_PASSWORD=your_admin_password
DOCUSEAL_API_KEY=your_docuseal_api_key
DOCUSEAL_ADULT_TEMPLATE_ID=your_adult_template_id
DOCUSEAL_YOUTH_TEMPLATE_ID=your_youth_template_id

# Stripe — plug in your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook secret from https://dashboard.stripe.com/webhooks (point to /api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...

# Site URL for Stripe checkout success/cancel redirects
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
